{
  "name": "@acme/starter-ui",
  "version": "0.1.0",
  "specification": "wippy-component-1.0",
  "title": "Acme Starter",
  "description": "Starter page web component for the acme/starter module.",
  "browser": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "package.json"
  ],
  "type": "module",
  "dependencies": {
    "@wippy-fe/theme": "^0.0.37",
    "@wippy-fe/webcomponent-core": "^0.0.37",
    "@wippy-fe/webcomponent-vue": "^0.0.37"
  },
  "devDependencies": {
    "@iconify/vue": "^5.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@wippy-fe/proxy": "^0.0.37",
    "@wippy-fe/vite-plugin": "^0.0.32",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.12"
  },
  "peerDependencies": {
    "@iconify/vue": "^5.0.0",
    "@wippy-fe/proxy": "^0.0.37",
    "vue": "^3.5.0"
  },
  "wippy": {
    "tagName": "acme-starter",
    "type": "component",
    "description": "Renders the acme/starter module status inside Kickside as a host-mounted web component. It accepts no props, loads its data through the authenticated Wippy proxy, and fills the host-provided content area using theme tokens that work in light and dark modes.",
    "props": {
      "type": "object",
      "properties": {}
    },
    "scripts": {
      "build": "build"
    }
  },
  "scripts": {
    "build": "vite build --outDir ../static --emptyOutDir",
    "dev": "vite build --watch --outDir ../static --emptyOutDir",
    "type-check": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  }
}
